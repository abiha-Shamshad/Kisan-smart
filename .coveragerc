[run]
source = app, website
omit = 
    */tests/*
    */venv/*
    */env/*
    */migrations/*
    */config.py
    */__init__.py

[report]
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[html]
directory = htmlcov
title = Kisan Smart Test Coverage Report

[xml]
output = coverage.xml
